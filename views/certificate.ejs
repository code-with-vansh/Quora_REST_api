<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Certificate | QuoraPosts</title>
    <script>
      (function () {
        var t = localStorage.getItem("qp-theme") || "light";
        document.documentElement.setAttribute("data-bs-theme", t);
      })();
    </script>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.css" rel="stylesheet">
    <link rel="stylesheet" href="/style.css">
</head>
<body>
    <%- include('partials/navbar') %>

    <main class="container min-vh-page">
        <h1 class="text-center text-accent mt-4">Verification is Completed</h1>
        <p class="text-center text-secondary">By clicking on this link you accepted that you are nonsense and you are ready to get your certificate.</p>

        <div class="certificate-box">
            <i class="bi bi-award display-3 text-accent mb-3 d-block"></i>
            <h2 class="cert-heading fst-italic mb-4">Certificate of Nonsense</h2>
            <p>This certificate is proudly awarded to</p>
            <h3 class="text-accent mb-4"><%= post.username %></h3>
            <p class="text-secondary">
                For outstanding contributions to the field of Nonsense and for consistently exceeding
                expectations in saying things that make absolutely no sense.<br>
                May your nonsense continue to inspire future generations.
            </p>
        </div>
    </main>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
    <script src="/theme.js"></script>
</body>
</html>
