<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Edit Post | QuoraPosts</title>
    <script>
      (function () {
        var t = localStorage.getItem("qp-theme") || "light";
        document.documentElement.setAttribute("data-bs-theme", t);
      })();
    </script>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.css" rel="stylesheet">
    <link rel="stylesheet" href="/style.css">
</head>
<body>
    <%- include('partials/navbar') %>

    <main class="container min-vh-page d-flex align-items-center justify-content-center">
        <div class="form-card p-4 p-md-5 w-100" style="max-width: 32rem;">
            <h2 class="mb-2 text-center">Edit <span class="text-accent">Post</span></h2>
            <p class="text-secondary small text-center mb-4">Post ID: <%= post.id %></p>
            <div class="d-flex align-items-center gap-3 mb-3">
                <div class="post-avatar"><%= post.username.charAt(0).toUpperCase() %></div>
                <h3 class="post-username h5 mb-0">@<%= post.username %></h3>
            </div>
            <form method="post" action="/posts/<%= post.id %>?_method=PATCH">
                <div class="mb-4">
                    <label for="content" class="form-label">Content</label>
                    <textarea class="form-control" id="content" name="content" rows="6"><%= post.content %></textarea>
                </div>
                <div class="d-flex gap-2">
                    <button type="submit" class="btn btn-accent flex-grow-1">
                        <i class="bi bi-check2-circle"></i> Save Changes
                    </button>
                    <a href="/posts" class="btn btn-outline-secondary">Cancel</a>
                </div>
            </form>
        </div>
    </main>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
    <script src="/theme.js"></script>
</body>
</html>
