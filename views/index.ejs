<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>All Posts | QuoraPosts</title>
    <script>
      (function () {
        var t = localStorage.getItem("qp-theme") || "light";
        document.documentElement.setAttribute("data-bs-theme", t);
      })();
    </script>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.css" rel="stylesheet">
    <link rel="stylesheet" href="/style.css">
</head>
<body>
    <%- include('partials/navbar') %>

    <main class="container min-vh-page">
        <div class="page-header text-center">
            <h1>Quora <span class="text-accent">Posts</span></h1>
            <p class="text-secondary">See what everyone is thinking about right now.</p>
        </div>

        <% if (posts.length === 0) { %>
            <div class="empty-state text-center text-secondary">
                <i class="bi bi-chat-square-text display-4 d-block mb-3"></i>
                <p class="mb-3">No posts yet. Be the first to share something!</p>
                <a href="/posts/new" class="btn btn-accent"><i class="bi bi-plus-lg"></i> Create a post</a>
            </div>
        <% } else { %>
            <div class="row g-4 pb-5">
                <% for (post of posts) { %>
                    <div class="col-12 col-md-6 col-lg-4">
                        <div class="post-card h-100 p-3 p-md-4 d-flex flex-column">
                            <div class="d-flex align-items-center gap-3 mb-3">
                                <div class="post-avatar"><%= post.username.charAt(0).toUpperCase() %></div>
                                <h3 class="post-username h6 mb-0">@<%= post.username %></h3>
                            </div>
                            <p class="post-content-index flex-grow-1"><%= post.content %></p>

                            <div class="d-flex flex-wrap gap-2 mt-3">
                                <a href="/posts/<%= post.id %>" class="btn btn-sm btn-outline-secondary">
                                    <i class="bi bi-eye"></i> View
                                </a>
                                <a href="/posts/<%= post.id %>/edit" class="btn btn-sm btn-outline-secondary">
                                    <i class="bi bi-pencil"></i> Edit
                                </a>
                                <a href="/posts/<%= post.id %>/delete" class="btn btn-sm btn-outline-danger">
                                    <i class="bi bi-trash3"></i> Delete
                                </a>
                            </div>
                            <a href="/posts/<%= post.id %>/error" class="small text-danger mt-2">Do not click here!</a>
                        </div>
                    </div>
                <% } %>
            </div>
        <% } %>
    </main>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
    <script src="/theme.js"></script>
</body>
</html>
